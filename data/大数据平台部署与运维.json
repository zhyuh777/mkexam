  {
    "id": "bd_s_01",
    "type": "short",
    "ch": "大数据平台部署与运维",
    "q": "请简述HDFS中NameNode和DataNode各自的功能。",
    "answer": "NameNode：管理文件系统的命名空间，维护文件与数据块的映射关系，处理客户端的元数据请求。DataNode：存储实际的数据块，执行数据块的读写操作，定期向NameNode汇报存储状态。",
    "exp": "①NameNode功能5分②DataNode功能5分",
    "difficulty": 2
  },
  {
    "id": "bd_s_02",
    "type": "short",
    "ch": "大数据平台部署与运维",
    "q": "请简述MapReduce中Map阶段和Reduce阶段的作用。",
    "answer": "Map阶段：将输入数据切分为多个分片，每个分片由一个Map任务处理，输出键值对形式的中间结果。Reduce阶段：接收Map阶段输出的键值对，将相同Key的数据进行合并归约，输出最终结果。",
    "exp": "①Map阶段作用5分②Reduce阶段作用5分",
    "difficulty": 2
  },
  {
    "id": "bd_s_03",
    "type": "short",
    "ch": "大数据平台部署与运维",
    "q": "请简述YARN的基本架构组件及其作用。",
    "answer": "ResourceManager：全局资源管理和调度，接收客户端提交的作业。NodeManager：每个节点上的代理，监控和管理本节点资源与任务。ApplicationMaster：每个应用一个，负责向ResourceManager申请资源和监控任务执行。Container：资源抽象单位，包含CPU和内存等资源。",
    "exp": "①ResourceManager3分②NodeManager2分③ApplicationMaster3分④Container2分",
    "difficulty": 2
  },
  {
    "id": "bd_s_04",
    "type": "short",
    "ch": "大数据平台部署与运维",
    "q": "请简述Kafka的基本架构及消息传递流程。",
    "answer": "Producer生产消息发送到指定Topic的Partition，消息按顺序存储在Partition中。Consumer订阅Topic，从Partition拉取消息进行消费。Broker是Kafka服务器节点，负责存储消息和处理请求。ZooKeeper管理Broker元数据和Consumer Group信息。",
    "exp": "①Producer发送消息2分②Partition存储2分③Consumer消费2分④Broker和ZooKeeper4分",
    "difficulty": 2
  }
]